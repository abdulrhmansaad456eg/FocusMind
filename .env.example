# Copy to ".env" for local dev (never commit real secrets).
# Expo loads EXPO_PUBLIC_* at bundle time — restart `npx expo start` after changes.

# Firebase Configuration
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google OAuth (for Google Sign-In)
# Get this from Firebase Console > Authentication > Sign-in method > Google > Web SDK configuration
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
